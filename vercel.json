{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "cad.robotlee.xyz"
        }
      ],
      "destination": "/cad/index.html"
    },
    {
      "source": "/index.html",
      "has": [
        {
          "type": "host",
          "value": "cad.robotlee.xyz"
        }
      ],
      "destination": "/cad/index.html"
    },
    {
      "source": "/(auto|cad|repair|web)",
      "destination": "/$1/index.html"
    }
  ]
}
